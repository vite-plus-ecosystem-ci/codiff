{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "factualGrounding": {
      "type": "integer",
      "minimum": 0,
      "maximum": 35
    },
    "prioritization": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30
    },
    "organization": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "specificity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    },
    "total": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "explanation": {
      "type": "string"
    },
    "majorErrors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "factualGrounding",
    "prioritization",
    "organization",
    "specificity",
    "total",
    "explanation",
    "majorErrors"
  ]
}
