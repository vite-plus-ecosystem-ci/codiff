#!/bin/sh
set -eu

source_path="$0"

while [ -L "$source_path" ]; do
  source_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
  linked_path="$(readlink "$source_path")"

  case "$linked_path" in
    /*) source_path="$linked_path" ;;
    *) source_path="$source_dir/$linked_path" ;;
  esac
done

script_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
app_path="$(CDPATH= cd -P "$script_dir/../../../.." >/dev/null 2>&1 && pwd)"

codiff_version() {
  sed -n 's/^  "version": "\([^"]*\)".*/\1/p' "$script_dir/../package.json"
}

show_help() {
  version="$(codiff_version)"
  blue_bold="$(printf '\033[1;34m')"
  gray="$(printf '\033[90m')"
  reset="$(printf '\033[0m')"

  printf '%s\n' "${blue_bold}codiff v${version}${reset} ${gray}A fast local diff viewer.${reset}"
  printf '\n'
  printf '%s\n' "${blue_bold}Usage:${reset} ${gray}codiff [options] [<ref> | <pr> | <url>] [path]${reset}"
  printf '\n'
  printf '%s\n' "${blue_bold}Options:${reset}"
  printf '  %-38s%s%s%s\n' "--agent <codex|claude|opencode|pi>" "$gray" "Override the agent backend for this session." "$reset"
  printf '  %-38s%s%s%s\n' "--branch <ref>" "$gray" "Review the current branch against a target branch." "$reset"
  printf '  %-38s%s%s%s\n' "--commit <ref>" "$gray" "Review a specific commit." "$reset"
  printf '  %-38s%s%s%s\n' "--codex-session <id>" "$gray" "Attach Codex session metadata to a walkthrough." "$reset"
  printf '  %-38s%s%s%s\n' "--claude-session <id>" "$gray" "Attach Claude Code session metadata to a walkthrough." "$reset"
  printf '  %-38s%s%s%s\n' "--help, -h" "$gray" "Show this help message and exit." "$reset"
  printf '  %-38s%s%s%s\n' "--opencode-session <id>" "$gray" "Attach OpenCode session metadata to a walkthrough." "$reset"
  printf '  %-38s%s%s%s\n' "--pi-session <id>" "$gray" "Attach Pi session metadata to a walkthrough." "$reset"
  printf '  %-38s%s%s%s\n' "--plan <file>" "$gray" "Edit a Markdown plan and wait until it is handed back." "$reset"
  printf '  %-38s%s%s%s\n' "--share" "$gray" "Share a walkthrough or a --plan file, then print its URL." "$reset"
  printf '  %-38s%s%s%s\n' "--version, -v" "$gray" "Show version number and exit." "$reset"
  printf '  %-38s%s%s%s\n' "--walkthrough, -w" "$gray" "Start an LLM walkthrough; use HEAD when there are no local changes." "$reset"
  printf '  %-38s%s%s%s\n' "--walkthrough-context <file>" "$gray" "Seed a walkthrough with Codex conversation context JSON." "$reset"
  printf '  %-38s%s%s%s\n' "--walkthrough-file <file>" "$gray" "Open a pre-authored narrative walkthrough JSON file." "$reset"
  printf '  %-38s%s%s%s\n' "--walkthrough-guide" "$gray" "Print the narrative walkthrough authoring guide and schema, then exit." "$reset"
  printf '\n'
  printf '%s\n' "${blue_bold}Examples:${reset}"
  printf '  %-32s%s%s%s\n' "codiff" "$gray" "Review staged and unstaged changes." "$reset"
  printf '  %-32s%s%s%s\n' "codiff /path/to/repo" "$gray" "Review changes in a specific repository." "$reset"
  printf '  %-32s%s%s%s\n' "codiff main" "$gray" "Review the current branch against main." "$reset"
  printf '  %-32s%s%s%s\n' "codiff a1b2c3d" "$gray" "Review a specific commit." "$reset"
  printf '  %-32s%s%s%s\n' "codiff '#75'" "$gray" "Review pull request #75." "$reset"
  printf '  %-32s%s%s%s\n' "codiff pr 75" "$gray" "Review pull request #75 (alternate syntax)." "$reset"
  printf '  %-32s%s%s%s\n' "codiff pr owner:feature" "$gray" "Review the open pull request for a branch." "$reset"
  printf '  %-32s%s%s%s\n' "codiff mr 75" "$gray" "Review GitLab merge request !75." "$reset"
  printf '  %-32s%s%s%s\n' "codiff --plan plan.md" "$gray" "Edit a plan and wait for handoff." "$reset"
  printf '  %-32s%s%s%s\n' "codiff --plan plan.md --share" "$gray" "Share a Markdown plan." "$reset"
  printf '  %-32s%s%s%s\n' "codiff -w" "$gray" "Walk through local changes, or HEAD when clean." "$reset"
  printf '  %-32s%s%s%s\n' "codiff -w a1b2c3d" "$gray" "Walkthrough a specific commit." "$reset"
  printf '  %-32s%s%s%s\n' "codiff --share" "$gray" "Share local changes, or HEAD when clean." "$reset"
  printf '  %-32s%s%s%s\n' "codiff --share HEAD" "$gray" "Share a walkthrough for a commit." "$reset"
}

for arg in "$@"; do
  if [ "$arg" = "--share" ] || [ "$arg" = "--public" ]; then
    runtime="${CODIFF_NODE_COMMAND:-}"
    if [ -z "$runtime" ]; then
      electron_exec="$(ls "$app_path/Contents/MacOS/" 2>/dev/null | head -n 1)"
      if [ -n "$electron_exec" ]; then
        runtime="$app_path/Contents/MacOS/$electron_exec"
      fi
    fi
    if [ -z "$runtime" ] || [ ! -x "$runtime" ]; then
      printf '%s\n' "codiff: could not find the bundled runtime for --share." >&2
      exit 1
    fi
    ELECTRON_RUN_AS_NODE=1 exec "$runtime" "$script_dir/codiff.js" "$@"
  fi
done

repository_path=""
codex_session_id=""
claude_session_id=""
opencode_session_id=""
pi_session_id=""
agent_backend=""
branch_ref=""
commit_ref=""
pull_request_source=""
pull_request_branch=""
pull_request_provider=""
source_ref=""
walkthrough_context_path=""
walkthrough_file_path=""
plan_file_path=""
plan_result_file_path=""
expect_codex_session=0
expect_claude_session=0
expect_opencode_session=0
expect_pi_session=0
expect_agent=0
expect_branch_ref=0
expect_commit_ref=0
expect_pull_request_value=0
expect_walkthrough_context=0
expect_walkthrough_file=0
expect_plan_file=0
expect_plan_result_file=0
walkthrough=0

is_commit_ref_arg() {
  ref_arg="$1"

  if [ -e "$ref_arg" ]; then
    return 1
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^[0-9a-fA-F]{4,64}$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^(@|HEAD)(([~^][0-9]*)|(\^\{[^}]+\})|(@\{[^}]+\}))*$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '(\^|~|@\{[^}]+\})'; then
    return 0
  fi

  return 1
}

is_explicit_path_arg() {
  case "$1" in
    /*|./*|../*) return 0 ;;
  esac

  return 1
}

is_git_branch_ref() {
  git -C "$1" show-ref --verify --quiet "refs/heads/$2" 2>/dev/null ||
    git -C "$1" show-ref --verify --quiet "refs/remotes/$2" 2>/dev/null
}

is_git_commit_ref() {
  git -C "$1" rev-parse --verify "$2^{commit}" >/dev/null 2>&1
}

is_git_repository() {
  git -C "$1" rev-parse --show-toplevel >/dev/null 2>&1
}

for arg in "$@"; do
  if [ "$expect_codex_session" -eq 1 ]; then
    codex_session_id="$arg"
    expect_codex_session=0
    continue
  fi

  if [ "$expect_claude_session" -eq 1 ]; then
    claude_session_id="$arg"
    expect_claude_session=0
    continue
  fi

  if [ "$expect_opencode_session" -eq 1 ]; then
    opencode_session_id="$arg"
    expect_opencode_session=0
    continue
  fi

  if [ "$expect_pi_session" -eq 1 ]; then
    pi_session_id="$arg"
    expect_pi_session=0
    continue
  fi

  if [ "$expect_agent" -eq 1 ]; then
    agent_backend="$arg"
    expect_agent=0
    continue
  fi

  if [ "$expect_branch_ref" -eq 1 ]; then
    branch_ref="$arg"
    expect_branch_ref=0
    continue
  fi

  if [ "$expect_commit_ref" -eq 1 ]; then
    commit_ref="$arg"
    expect_commit_ref=0
    continue
  fi

  if [ "$expect_walkthrough_context" -eq 1 ]; then
    walkthrough_context_path="$arg"
    expect_walkthrough_context=0
    continue
  fi

  if [ "$expect_walkthrough_file" -eq 1 ]; then
    walkthrough_file_path="$arg"
    expect_walkthrough_file=0
    continue
  fi

  if [ "$expect_plan_file" -eq 1 ]; then
    plan_file_path="$arg"
    expect_plan_file=0
    continue
  fi

  if [ "$expect_plan_result_file" -eq 1 ]; then
    plan_result_file_path="$arg"
    expect_plan_result_file=0
    continue
  fi

  if [ "$expect_pull_request_value" -eq 1 ]; then
    if printf '%s' "$arg" | grep -Eq '^#?[1-9][0-9]*$'; then
      pull_request_source="#$arg"
      pull_request_source="$(printf '%s' "$pull_request_source" | tr -d '#')"
      expect_pull_request_value=0
      continue
    fi
    if [ "$pull_request_provider" = "pr" ]; then
      pull_request_branch="$arg"
      expect_pull_request_value=0
      continue
    fi
    expect_pull_request_value=0
  fi

  case "$arg" in
    --help|-h)
      show_help
      exit 0
      ;;
    --version|-v)
      printf 'codiff v%s\n' "$(codiff_version)"
      exit 0
      ;;
    --walkthrough-guide)
      # The guide is pure text assembled by the Node entry; run it with the
      # bundled Electron as Node so no separate node install is required.
      electron_exec="$(ls "$app_path/Contents/MacOS/" 2>/dev/null | head -n 1)"
      if [ -n "$electron_exec" ] && [ -f "$script_dir/codiff.js" ]; then
        ELECTRON_RUN_AS_NODE=1 "$app_path/Contents/MacOS/$electron_exec" \
          "$script_dir/codiff.js" --walkthrough-guide
      else
        cat "$script_dir/walkthrough-guide.md"
      fi
      exit 0
      ;;
    --walkthrough|-w)
      walkthrough=1
      ;;
    --codex-session)
      expect_codex_session=1
      ;;
    --codex-session=*)
      codex_session_id="${arg#--codex-session=}"
      ;;
    --claude-session)
      expect_claude_session=1
      ;;
    --claude-session=*)
      claude_session_id="${arg#--claude-session=}"
      ;;
    --opencode-session)
      expect_opencode_session=1
      ;;
    --opencode-session=*)
      opencode_session_id="${arg#--opencode-session=}"
      ;;
    --pi-session)
      expect_pi_session=1
      ;;
    --pi-session=*)
      pi_session_id="${arg#--pi-session=}"
      ;;
    --agent)
      expect_agent=1
      ;;
    --agent=*)
      agent_backend="${arg#--agent=}"
      ;;
    --branch)
      expect_branch_ref=1
      ;;
    --branch=*)
      branch_ref="${arg#--branch=}"
      ;;
    --commit)
      expect_commit_ref=1
      ;;
    --commit=*)
      commit_ref="${arg#--commit=}"
      ;;
    --walkthrough-context)
      expect_walkthrough_context=1
      ;;
    --walkthrough-context=*)
      walkthrough_context_path="${arg#--walkthrough-context=}"
      ;;
    --walkthrough-file)
      expect_walkthrough_file=1
      ;;
    --walkthrough-file=*)
      walkthrough_file_path="${arg#--walkthrough-file=}"
      ;;
    --plan)
      expect_plan_file=1
      ;;
    --plan=*)
      plan_file_path="${arg#--plan=}"
      ;;
    --plan-file)
      expect_plan_file=1
      ;;
    --plan-file=*)
      plan_file_path="${arg#--plan-file=}"
      ;;
    --plan-result-file)
      expect_plan_result_file=1
      ;;
    --plan-result-file=*)
      plan_result_file_path="${arg#--plan-result-file=}"
      ;;
    -*)
      ;;
    *)
      if [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eiq '^(pr|pull-request)$'; then
        pull_request_provider="pr"
        expect_pull_request_value=1
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eiq '^(mr|merge-request)$'; then
        pull_request_provider="mr"
        expect_pull_request_value=1
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^#[1-9][0-9]*$'; then
        pull_request_source="$arg"
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^https?://[^/]+/(.+/)?[^/]+/(-/merge_requests|pull)/[0-9]+/?$'; then
        pull_request_source="$arg"
      elif [ -z "$commit_ref" ] && [ -z "$branch_ref" ] && [ -z "$source_ref" ] && ! is_explicit_path_arg "$arg"; then
        source_ref="$arg"
      elif [ -z "$repository_path" ]; then
        repository_path="$arg"
      fi
      ;;
  esac
done

if [ -n "$plan_file_path" ] && [ -n "$source_ref" ] && [ -z "$repository_path" ]; then
  repository_path="$source_ref"
  source_ref=""
fi

if [ -n "$source_ref" ] && [ -z "$commit_ref" ] && [ -z "$branch_ref" ]; then
  repository_context="${repository_path:-$PWD}"
  case "$repository_context" in
    /*) ;;
    *) repository_context="$PWD/$repository_context" ;;
  esac

  if is_commit_ref_arg "$source_ref" && is_git_commit_ref "$repository_context" "$source_ref"; then
    commit_ref="$source_ref"
  elif is_git_branch_ref "$repository_context" "$source_ref"; then
    branch_ref="$source_ref"
  elif is_git_commit_ref "$repository_context" "$source_ref" || is_commit_ref_arg "$source_ref"; then
    commit_ref="$source_ref"
  elif [ -z "$repository_path" ] && [ -e "$source_ref" ]; then
    repository_path="$source_ref"
  elif is_git_repository "$repository_context"; then
    branch_ref="$source_ref"
  elif [ -z "$repository_path" ]; then
    repository_path="$source_ref"
  fi
fi

repository_path="${repository_path:-$PWD}"

case "$repository_path" in
  /*) ;;
  *) repository_path="$PWD/$repository_path" ;;
esac

if [ -n "$walkthrough_context_path" ]; then
  case "$walkthrough_context_path" in
    /*) ;;
    *) walkthrough_context_path="$PWD/$walkthrough_context_path" ;;
  esac
fi

if [ -n "$walkthrough_file_path" ]; then
  case "$walkthrough_file_path" in
    /*) ;;
    *) walkthrough_file_path="$PWD/$walkthrough_file_path" ;;
  esac
fi

if [ -n "$plan_file_path" ]; then
  case "$plan_file_path" in
    /*) ;;
    *) plan_file_path="$PWD/$plan_file_path" ;;
  esac
  if [ ! -f "$plan_file_path" ] || ! printf '%s' "$plan_file_path" | grep -Eiq '\.md$'; then
    printf '%s\n' "codiff: plan file not found or not Markdown: $plan_file_path" >&2
    exit 1
  fi
fi

if [ -n "$plan_result_file_path" ]; then
  case "$plan_result_file_path" in
    /*) ;;
    *) plan_result_file_path="$PWD/$plan_result_file_path" ;;
  esac
fi

if [ -n "$pull_request_branch" ]; then
  if ! pull_request_source="$(
    cd "$repository_path" 2>/dev/null &&
      gh pr view "$pull_request_branch" \
        --json state,url \
        --jq 'select(.state == "OPEN") | .url' 2>/dev/null
  )" || [ -z "$pull_request_source" ]; then
    printf '%s\n' \
      "codiff: Could not find an open GitHub pull request for branch \"$pull_request_branch\"." \
      >&2
    exit 1
  fi
  pull_request_provider=""
fi

open_codiff() {
  # Prepend optional flags in reverse of their final order so the resulting
  # argument list reads: --codex-session --claude-session --opencode-session
  # --agent --walkthrough-context --walkthrough-file --plan-file
  # --plan-result-file <trailing>.
  if [ -n "$plan_result_file_path" ]; then
    set -- --plan-result-file "$plan_result_file_path" "$@"
  fi
  if [ -n "$plan_file_path" ]; then
    set -- --plan-file "$plan_file_path" "$@"
  fi
  if [ -n "$walkthrough_file_path" ]; then
    set -- --walkthrough-file "$walkthrough_file_path" "$@"
  fi
  if [ -n "$walkthrough_context_path" ]; then
    set -- --walkthrough-context "$walkthrough_context_path" "$@"
  fi
  if [ -n "$agent_backend" ]; then
    set -- --agent "$agent_backend" "$@"
  fi
  if [ -n "$opencode_session_id" ]; then
    set -- --opencode-session "$opencode_session_id" "$@"
  fi
  if [ -n "$claude_session_id" ]; then
    set -- --claude-session "$claude_session_id" "$@"
  fi
  if [ -n "$codex_session_id" ]; then
    set -- --codex-session "$codex_session_id" "$@"
  fi
  if [ -n "$pi_session_id" ]; then
    set -- --pi-session "$pi_session_id" "$@"
  fi

  open -n "$app_path" --args "$@"
}

if [ -n "$plan_file_path" ]; then
  if [ -z "$plan_result_file_path" ]; then
    plan_result_directory="$(mktemp -d "${TMPDIR:-/tmp}/codiff-plan-result.XXXXXX")"
    plan_result_file_path="$plan_result_directory/result.json"
    trap 'rm -rf "$plan_result_directory"' EXIT INT TERM
  fi
  open_codiff "$repository_path"
  plan_open_attempts=0
  plan_app_pid=""
  while :; do
    if [ -s "$plan_result_file_path" ]; then
      if grep -Eq '"status"[[:space:]]*:[[:space:]]*"(done|closed)"' "$plan_result_file_path"; then
        printf 'CODIFF_PLAN_RESULT '
        cat "$plan_result_file_path"
        exit 0
      fi
      if grep -Eq '"status"[[:space:]]*:[[:space:]]*"canceled"' "$plan_result_file_path"; then
        exit 2
      fi
      if grep -Eq '"status"[[:space:]]*:[[:space:]]*"open"' "$plan_result_file_path"; then
        plan_app_pid="$(sed -n 's/.*"pid"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$plan_result_file_path")"
      fi
    fi
    if [ -n "$plan_app_pid" ] && ! kill -0 "$plan_app_pid" 2>/dev/null; then
      exit 2
    fi
    plan_open_attempts=$((plan_open_attempts + 1))
    if [ -z "$plan_app_pid" ] && [ "$plan_open_attempts" -ge 300 ]; then
      printf '%s\n' "codiff: the app did not open the plan within 15 seconds." >&2
      exit 1
    fi
    sleep 0.05
  done
elif [ -n "$pull_request_source" ] && [ -n "$pull_request_provider" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough "$pull_request_provider" "$pull_request_source" "$repository_path"
elif [ -n "$pull_request_source" ] && [ -n "$pull_request_provider" ]; then
  open_codiff "$pull_request_provider" "$pull_request_source" "$repository_path"
elif [ -n "$pull_request_source" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough "$pull_request_source" "$repository_path"
elif [ -n "$pull_request_source" ]; then
  open_codiff "$pull_request_source" "$repository_path"
elif [ -n "$commit_ref" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough --commit "$commit_ref" "$repository_path"
elif [ -n "$commit_ref" ]; then
  open_codiff --commit "$commit_ref" "$repository_path"
elif [ -n "$branch_ref" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough --branch "$branch_ref" "$repository_path"
elif [ -n "$branch_ref" ]; then
  open_codiff --branch "$branch_ref" "$repository_path"
elif [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough "$repository_path"
else
  open_codiff "$repository_path"
fi
