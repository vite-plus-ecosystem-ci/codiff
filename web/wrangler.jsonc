{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "codiff",
  "compatibility_date": "2026-07-16",
  "workers_dev": false,
  "vars": {
    "PUBLIC_ORIGIN": "https://codiff.dev",
  },
  "secrets": {
    "required": ["AUTH_GITHUB_CLIENT_ID", "AUTH_GITHUB_CLIENT_SECRET", "BETTER_AUTH_SECRET"],
  },
  "routes": [
    {
      "pattern": "codiff.dev",
      "custom_domain": true,
    },
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "FATE_LIVE",
        "class_name": "FateLiveDurableObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "fate-live-v1",
      "new_sqlite_classes": ["FateLiveDurableObject"],
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codiff-public",
      "migrations_dir": "./db/migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "WALKTHROUGH_BUCKET",
      "bucket_name": "codiff-public-shares",
    },
  ],
}
