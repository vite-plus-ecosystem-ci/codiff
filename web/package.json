{
  "name": "@nkzw/codiff-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "db:migrate": "vp exec wrangler d1 migrations apply codiff-public --local",
    "db:migrate:remote": "vp exec wrangler d1 migrations apply DB --remote",
    "deploy": "vp build && vp run db:migrate:remote && vp exec wrangler deploy",
    "deploy:dry-run": "vp build && vp exec wrangler deploy --dry-run",
    "dev": "vp run db:migrate && vp dev",
    "fate:generate": "node ../node_modules/react-fate/lib/cli.mjs generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@nkzw/codiff-core": "workspace:*",
    "@nkzw/codiff-service": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@void/react": "0.10.10",
    "better-auth": "^1.6.23",
    "cf-fate": "^1.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-fate": "^1.3.1",
    "void": "^0.10.10"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.111.0"
  }
}
