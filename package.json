{
  "name": "codiff",
  "version": "1.9.1",
  "private": true,
  "description": "A fast local diff viewer.",
  "license": "MIT",
  "author": {
    "name": "Christoph Nakazawa",
    "email": "christoph.pojer@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkzw-tech/codiff.git"
  },
  "bin": {
    "codiff": "./bin/codiff.js"
  },
  "files": [
    "bin",
    "claude",
    "config",
    "codex",
    "core",
    "dist",
    "electron",
    "opencode",
    "pi"
  ],
  "type": "module",
  "main": "./electron/main.cjs",
  "scripts": {
    "build": "vp run --filter '@nkzw/codiff-core' build && vp run --filter '@nkzw/codiff-service' build && vp run --filter '@nkzw/codiff-web' build && vp build",
    "codiff": "node ./bin/codiff.js",
    "dev": "vp dev --host 127.0.0.1",
    "dev:app": "ELECTRON_RENDERER_URL=http://127.0.0.1:5173 node ./bin/codiff.js",
    "electron": "electron .",
    "eval:walkthrough": "node ./evals/run.mjs",
    "forge:make": "electron-forge make",
    "forge:package": "electron-forge package",
    "link:global": "vp build && pnpm link --global",
    "make": "vpr build && electron-forge make",
    "make:ci": "vpr build && electron-forge make && electron-forge package --platform=linux --arch=x64 && electron-forge make --platform=win32",
    "make:mac": "vpr build && electron-forge make --platform=darwin --arch=arm64",
    "package:app": "vp build && electron-forge package",
    "prepack": "vp build",
    "prepare": "vp config",
    "test": "vp test",
    "test:integration": "vp run build && vp test -c vitest.cloudflare.config.ts"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.2.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^43.1.1",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ghostty-web": "^0.4.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.6",
  "build": {
    "appId": "dev.nkzw-tech.codiff",
    "copyright": "Copyright © 2026-current Nakazawa Tech",
    "productName": "Codiff"
  }
}
